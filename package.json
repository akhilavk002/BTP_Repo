{
  "name": "mycapapp",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.9",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-managepo": "cds watch --profile hybrid --open anubhav.ui.managepo/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/managepo"
  ],
  "cds": {
    "requires": {
      "[development]": {
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": "db.sqlite"
          }
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "anubhav": {
              "password": "Welcome1",
              "roles": ["Display", "Edit"],
              "attr": {
                "spiderman": ["My Bank of London"]
              }
            },
            "ananya": {
              "password": "ananya",
              "roles": ["Edit"]
            }
          }
        }
      },
      "[hybrid]": {
        "db": {
          "kind": "hana"
        },
        "auth": {
          "kind": "mocked",
          "users": {
            "anubhav": {
              "password": "Welcome1",
              "roles": ["Display", "Edit"],
              "attr": {
                "spiderman": ["My Bank of London"]
              }
            },
            "ananya": {
              "password": "ananya",
              "roles": ["Edit"]
            }
          }
        }
      },
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  }
}